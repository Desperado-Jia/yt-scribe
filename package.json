    "dev:worker": "node scripts/generate-subtitle-map.mjs && wrangler dev"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "esbuild": "^0.28.1",
    "marked": "^18.0.5",
    "miniflare": "^4.20260611.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
